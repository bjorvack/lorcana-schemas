{
  "$ref": "#/definitions/tournament",
  "definitions": {
    "tournament": {
      "type": "object",
      "properties": {
        "sourceUrl": {
          "type": "string",
          "format": "uri"
        },
        "sourceName": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "decks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "placement": {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": 1
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "player": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "deck": {
                "type": "object",
                "properties": {
                  "inks": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "Amber",
                        "Amethyst",
                        "Emerald",
                        "Ruby",
                        "Sapphire",
                        "Steel"
                      ]
                    },
                    "minItems": 1,
                    "maxItems": 2
                  },
                  "cards": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "cardId": {
                          "type": "string",
                          "minLength": 1
                        },
                        "count": {
                          "type": "integer",
                          "minimum": 1
                        }
                      },
                      "required": [
                        "cardId",
                        "count"
                      ],
                      "additionalProperties": false
                    },
                    "minItems": 1
                  },
                  "name": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "source": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                },
                "required": [
                  "inks",
                  "cards",
                  "name",
                  "source"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "placement",
              "player",
              "deck"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        }
      },
      "required": [
        "sourceUrl",
        "sourceName",
        "name",
        "date",
        "decks"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
