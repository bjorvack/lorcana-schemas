{
  "$ref": "#/definitions/rotation",
  "definitions": {
    "rotation": {
      "type": "object",
      "properties": {
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "sourceUrl": {
          "type": "string",
          "format": "uri"
        },
        "schemaVersion": {
          "type": "string"
        },
        "blocks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "setCodes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "minItems": 1
              },
              "releaseDate": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "rotationDate": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              }
            },
            "required": [
              "name",
              "setCodes",
              "releaseDate",
              "rotationDate"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "coreConstructedCutoffMonths": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "generatedAt",
        "sourceUrl",
        "schemaVersion",
        "blocks",
        "coreConstructedCutoffMonths"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
