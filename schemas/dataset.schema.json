{
  "$ref": "#/definitions/dataset",
  "definitions": {
    "dataset": {
      "type": "object",
      "properties": {
        "datasetVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "schemaVersion": {
          "type": "string",
          "minLength": 1
        },
        "cardSetVersion": {
          "type": "string",
          "minLength": 1
        },
        "cardsReleaseTag": {
          "type": "string",
          "minLength": 1
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "tournaments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sourceUrl": {
                "type": "string",
                "format": "uri"
              },
              "sourceName": {
                "type": "string",
                "minLength": 1
              },
              "externalKey": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "date": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "decks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "placement": {
                      "anyOf": [
                        {
                          "type": "integer",
                          "minimum": 1
                        },
                        {
                          "type": "null"
                        }
                      ]
                    },
                    "player": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "deck": {
                      "type": "object",
                      "properties": {
                        "inks": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": [
                              "Amber",
                              "Amethyst",
                              "Emerald",
                              "Ruby",
                              "Sapphire",
                              "Steel"
                            ]
                          },
                          "minItems": 1,
                          "maxItems": 2
                        },
                        "cards": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "cardId": {
                                "type": "string",
                                "minLength": 1
                              },
                              "count": {
                                "type": "integer",
                                "minimum": 1
                              }
                            },
                            "required": [
                              "cardId",
                              "count"
                            ],
                            "additionalProperties": false
                          },
                          "minItems": 1
                        },
                        "name": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "source": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "externalKey": {
                          "type": "string",
                          "minLength": 1
                        },
                        "externalUrl": {
                          "type": "string",
                          "format": "uri"
                        }
                      },
                      "required": [
                        "inks",
                        "cards",
                        "name",
                        "source"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "placement",
                    "player",
                    "deck"
                  ],
                  "additionalProperties": false
                },
                "minItems": 1
              }
            },
            "required": [
              "sourceUrl",
              "sourceName",
              "name",
              "date",
              "decks"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "datasetVersion",
        "schemaVersion",
        "cardSetVersion",
        "cardsReleaseTag",
        "generatedAt",
        "sources",
        "tournaments"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
