{
  "name": "@bjorvack/lorcana-schemas",
  "version": "0.1.0",
  "description": "Shared zod schemas + JSON Schema for the Lorcana deckbuilder pipeline.",
  "license": "MIT",
  "author": "bjorvack",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas",
    "CHANGELOG.md",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bjorvack/lorcana-schemas.git"
  },
  "scripts": {
    "build": "tsup",
    "build:schemas": "tsx scripts/build-json-schemas.ts",
    "check:bump": "tsx scripts/check-bump.ts",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.9.0",
    "prettier": "^3.3.0",
    "tsup": "^8.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^2.0.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.15.1"
}
